-- Test AU: int_to_base_p utility
#eval assertPy "P = 2**31 - 2**24 + 1\n\ndef int_to_base_p(value, num_limbs):\n    limbs = []\n    acc = value\n    for _ in range(num_limbs):\n        limbs.append(acc % P)\n        acc = acc // P\n    return limbs\n\n# 0 decomposes to all zeros\nprint(int_to_base_p(0, 3))\n\n# P + 1 decomposes to [1, 1] in base P\nprint(int_to_base_p(P + 1, 2))\n\n# P*P + 2*P + 3 = [3, 2, 1]\nprint(int_to_base_p(P * P + 2 * P + 3, 3))\n\n# Single limb is just value mod P\nprint(int_to_base_p(42, 1))\n\n# Reconstruction check\nlimbs = int_to_base_p(123456789012345, 5)\nreconstructed = sum(l * P**i for i, l in enumerate(limbs))\nprint(reconstructed == 123456789012345)" "[0, 0, 0]\n[1, 1]\n[3, 2, 1]\n[42]\nTrue\n"

-- Test AV: PRF using SHAKE128 — _bytes_to_field_elements
#eval assertPy "import hashlib\n\nP = 2**31 - 2**24 + 1\nPRF_BYTES_PER_FE = 16\nHASH_LEN_FE = 8\n\ndef bytes_to_field_elements(data, count):\n    return [\n        int.from_bytes(data[i:i+PRF_BYTES_PER_FE], 'big') % P\n        for i in range(0, count * PRF_BYTES_PER_FE, PRF_BYTES_PER_FE)\n    ]\n\ndef prf_apply(key, epoch, chain_index):\n    domain_sep = b'\\xae\\xae\\x22\\xff\\x00\\x01\\xfa\\xff\\x21\\xaf\\x12\\x00\\x01\\x11\\xff\\x00'\n    input_data = (\n        domain_sep + b'\\x00' + key\n        + epoch.to_bytes(4, 'big')\n        + chain_index.to_bytes(8, 'big')\n    )\n    num_bytes = PRF_BYTES_PER_FE * HASH_LEN_FE\n    output = hashlib.shake_128(input_data).digest(num_bytes)\n    return bytes_to_field_elements(output, HASH_LEN_FE)\n\n# Test with known key\nkey = b'\\x42' * 32\nresult = prf_apply(key, 0, 0)\nprint(len(result))\nprint(all(0 <= v < P for v in result))\n\n# Deterministic\nresult2 = prf_apply(key, 0, 0)\nprint(result == result2)\n\n# Different key -> different output\nkey2 = b'\\x43' * 32\nresult3 = prf_apply(key2, 0, 0)\nprint(result != result3)\n\n# Different epoch -> different output\nresult4 = prf_apply(key, 1, 0)\nprint(result != result4)" "8\nTrue\nTrue\nTrue\nTrue\n"

-- Test AW: Tweak encoding and hash chain
#eval assertPy "P = 2**31 - 2**24 + 1\n\ndef int_to_base_p(value, num_limbs):\n    limbs = []\n    acc = value\n    for _ in range(num_limbs):\n        limbs.append(acc % P)\n        acc = acc // P\n    return limbs\n\nTWEAK_PREFIX_TREE = 0x01\nTWEAK_PREFIX_CHAIN = 0x00\nTWEAK_LEN_FE = 2\n\nclass TreeTweak:\n    def __init__(self, level, index):\n        self.level = level\n        self.index = index\n\nclass ChainTweak:\n    def __init__(self, epoch, chain_index, step):\n        self.epoch = epoch\n        self.chain_index = chain_index\n        self.step = step\n\ndef encode_tweak(tweak, length):\n    if isinstance(tweak, TreeTweak):\n        acc = (tweak.level << 40) | (int(tweak.index) << 8) | TWEAK_PREFIX_TREE\n    elif isinstance(tweak, ChainTweak):\n        acc = (int(tweak.epoch) << 24) | (tweak.chain_index << 16) | (tweak.step << 8) | TWEAK_PREFIX_CHAIN\n    else:\n        raise TypeError('Unknown tweak type')\n    return int_to_base_p(acc, length)\n\n# Tree tweaks with different parameters produce different encodings\nt1 = encode_tweak(TreeTweak(0, 0), TWEAK_LEN_FE)\nt2 = encode_tweak(TreeTweak(1, 0), TWEAK_LEN_FE)\nt3 = encode_tweak(TreeTweak(0, 1), TWEAK_LEN_FE)\nprint(t1 != t2)\nprint(t1 != t3)\nprint(t2 != t3)\n\n# Chain tweaks produce different encodings from tree tweaks\nc1 = encode_tweak(ChainTweak(0, 0, 1), TWEAK_LEN_FE)\nprint(c1 != t1)\n\n# Chain tweaks are deterministic\nc2 = encode_tweak(ChainTweak(0, 0, 1), TWEAK_LEN_FE)\nprint(c1 == c2)" "True\nTrue\nTrue\nTrue\nTrue\n"

