24 = [\n    (-2)%P, 1, 2, pow(2,P-2,P), 3, 4, (-pow(2,P-2,P))%P, (-3)%P,\n    (-4)%P, pow(256,P-2,P), pow(4,P-2,P), pow(8,P-2,P),\n    pow(16,P-2,P), pow(32,P-2,P), pow(64,P-2,P), pow(2**24,P-2,P),\n    (-pow(256,P-2,P))%P, (-pow(8,P-2,P))%P, (-pow(16,P-2,P))%P,\n    (-pow(32,P-2,P))%P, (-pow(64,P-2,P))%P, (-pow(128,P-2,P))%P,\n    (-pow(512,P-2,P))%P, (-pow(2**24,P-2,P))%P,\n]\n\nHASH_LEN_FE = 8\n\ndef compress(input_vec, rc, diag, width, output_len):\n    padded = list(input_vec) + [0]*(width - len(input_vec))\n    permuted = do_permute(padded, rc, diag, M4T, width, 4, (20 if width==16 else 23), P)\n    return [(permuted[i]+padded[i])%P for i in range(width)][:output_len]\n\ndef int_to_base_p(value, num_limbs):\n    limbs = []\n    acc = value\n    for _ in range(num_limbs):\n        limbs.append(acc % P)\n        acc //= P\n    return limbs\n\ndef tree_hash(param, level, index, left, right):\n    tweak = int_to_base_p((level << 40) | (index << 8) | 0x01, 2)\n    input_vec = param + tweak + left + right\n    return compress(input_vec, RC24, DIAG24, 24, HASH_LEN_FE)\n\n# Build a tiny Merkle tree with 4 leaves (depth 2)\nparam = [100, 200, 300, 400, 500]\nleaf0 = [10, 20, 30, 40, 50, 60, 70, 80]\nleaf1 = [11, 21, 31, 41, 51, 61, 71, 81]\nleaf2 = [12, 22, 32, 42, 52, 62, 72, 82]\nleaf3 = [13, 23, 33, 43, 53, 63, 73, 83]\n\n# Build tree: level 0 = leaves, level 1 = internal, level 2 = root\nnode_01 = tree_hash(param, 0, 0, leaf0, leaf1)\nnode_23 = tree_hash(param, 0, 1, leaf2, leaf3)\nroot = tree_hash(param, 1, 0, node_01, node_23)\n\nprint(len(root))\nprint(all(0 <= v < P for v in root))\n\n# Path for leaf0: sibling = leaf1, then sibling = node_23\n# Verify: recompute root from leaf0 + path\nrecomputed_01 = tree_hash(param, 0, 0, leaf0, leaf1)\nrecomputed_root = tree_hash(param, 1, 0, recomputed_01, node_23)\nprint(root == recomputed_root)\n\n# Wrong leaf should give different root\nwrong_leaf = [99, 20, 30, 40, 50, 60, 70, 80]\nwrong_01 = tree_hash(param, 0, 0, wron