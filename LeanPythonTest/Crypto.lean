v, 1, 0)\nprint(sum(vertex1) == (w-1) * v - 1)  # sum = 11\n\n# Round-trip: find_layer then map_to_vertex for several indices\nfor x in [0, 1, 5, 50, 100, 200, 255]:\n    (d, remainder) = hypercube_find_layer(w, v, x)\n    vertex = map_to_vertex(w, v, d, remainder)\n    # Verify vertex coordinates are valid\n    assert all(0 <= c < w for c in vertex), f'Invalid coords: {vertex}'\n    assert len(vertex) == v\n    # Verify sum matches the layer\n    expected_sum = (w-1) * v - d\n    assert sum(vertex) == expected_sum, f'Sum mismatch: {sum(vertex)} != {expected_sum}'\nprint('all round-trips passed')" "[3, 3, 3, 3]\nTrue\nTrue\nall round-trips passed\n"

