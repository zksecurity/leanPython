-- Phase 9f: Cryptographic subspecs tests
-- KoalaBear field arithmetic, Poseidon2 hash, XMSS signature scheme

import LeanPython.Interpreter.Core

set_option autoImplicit false
set_option maxHeartbeats 800000

open LeanPython.Interpreter

private def assertPy (source expected : String) : IO Unit := do
  match ← interpret source with
  | .ok lines =>
    let actual := String.join lines
    if actual != expected then
      throw <| IO.userError
        s!"Python output mismatch.\nExpected: {repr expected}\nActual:   {repr actual}\nSource:\n{source}"
  | .error msg =>
    throw <| IO.userError s!"Python error: {msg}\nSource:\n{source}"

