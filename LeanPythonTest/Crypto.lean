-- Test AQ: Fp arithmetic — addition, subtraction, negation, multiplication, pow, inverse, division
#eval assertPy "P = 2**31 - 2**24 + 1\n\nclass Fp:\n    def __init__(self, value):\n        if not isinstance(value, int) or isinstance(value, bool):\n            raise TypeError('Field value must be an integer')\n        self.value = value % P\n    def __add__(self, other):\n        return Fp(value=self.value + other.value)\n    def __sub__(self, other):\n        return Fp(value=self.value - other.value)\n    def __neg__(self):\n        return Fp(value=-self.value)\n    def __mul__(self, other):\n        return Fp(value=self.value * other.value)\n    def __pow__(self, exponent):\n        return Fp(value=pow(self.value, exponent, P))\n    def inverse(self):\n        if self.value == 0:\n            raise ZeroDivisionError('Cannot invert zero')\n        return self ** (P - 2)\n    def __truediv__(self, other):\n        return self * other.inverse()\n    def __eq__(self, other):\n        if not isinstance(other, Fp):\n            return False\n        return self.value == other.value\n    def __hash__(self):\n        return hash(self.value)\n    def __str__(self):\n        return 'Fp(value=' + str(self.value) + ')'\n\n# Basic arithmetic\nprint(Fp(3) + Fp(5))\nprint(Fp(10) - Fp(3))\nprint(Fp(2) * Fp(7))\n\n# Modular reduction (wraparound)\nprint(Fp(P - 1) + Fp(2))\nprint(Fp(0) - Fp(1))\n\n# Negation\nprint(-Fp(1) == Fp(P - 1))\nprint(-Fp(0) == Fp(0))\n\n# Exponentiation\nprint(Fp(2) ** 10)\n\n# Inverse and division round-trip\nhalf = Fp(1) / Fp(2)\nprint(half * Fp(2))\nprint(Fp(7).inverse() * Fp(7))\n\n# Division\nprint(Fp(6) / Fp(3))\n\n# Zero division\ntry:\n    Fp(0).inverse()\n    print('ERROR')\nexcept ZeroDivisionError:\n    print('caught')\n\n# Equality\nprint(Fp(42) == Fp(42))\nprint(Fp(42) == Fp(43))" "Fp(value=8)\nFp(value=7)\nFp(value=14)\nFp(value=1)\nFp(value=2130706432)\nTrue\nTrue\nFp(value=1024)\nFp(value=1)\nFp(value=1)\nFp(value=2)\ncaught\nTrue\nFalse\n"

-- Test AR: Fp serialization round-trip via io.BytesIO
#eval assertPy "import io\n\nP = 2**31 - 2**24 + 1\nP_BYTES = 4\n\nclass Fp:\n    def __init__(self, value):\n        self.value = value % P\n    def __eq__(self, other):\n        if not isinstance(other, Fp):\n            return False\n        return self.value == other.value\n    def serialize(self, stream):\n        stream.write(self.value.to_bytes(P_BYTES, 'little'))\n        return P_BYTES\n    @classmethod\n    def deserialize(cls, stream, scope):\n        data = stream.read(P_BYTES)\n        value = int.from_bytes(data, 'little')\n        if value >= P:\n            raise ValueError('Value exceeds field modulus')\n        return cls(value=value)\n\n# Round-trip test\nfor v in [0, 1, 42, P - 1, 1000000]:\n    fp = Fp(value=v)\n    buf = io.BytesIO()\n    fp.serialize(buf)\n    buf.seek(0)\n    fp2 = Fp.deserialize(buf, P_BYTES)\n    print(fp == fp2)\n\n# Test bytes representation\nfp = Fp(value=42)\nbuf = io.BytesIO()\nfp.serialize(buf)\nprint(buf.getvalue().hex())" "True\nTrue\nTrue\nTrue\nTrue\n2a000000\n"

